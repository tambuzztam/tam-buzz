---
import Layout from '../layouts/Layout.astro';
import CTAButton from '../components/ui/CTAButton.astro';
---

<Layout 
  title="Tam Listen - Audio Player for Power Listeners"
  description="An audio player for power listeners. Own your files. Manage your library. Listen to everything — even video — as audio."
>
  <main>
    <!-- Hero Section -->
    <section class="min-h-screen flex items-center justify-center px-6 py-20">
      <div class="max-w-4xl mx-auto text-center">
        <div class="mb-8">
          <!-- App Icon Placeholder -->
          <div class="w-24 h-24 mx-auto mb-8 bg-gradient-to-br from-blue-400 to-purple-600 rounded-2xl flex items-center justify-center shadow-2xl">
            <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
            </svg>
          </div>
        </div>
        
        <h1 class="text-5xl md:text-7xl font-bold mb-6 bg-gradient-to-r from-white via-blue-200 to-purple-300 bg-clip-text text-transparent">
          Tam Listen
        </h1>
        
        <p class="text-xl md:text-2xl text-gray-300 mb-4 font-light">
          An audio player for power listeners.
        </p>
        
        <p class="text-lg md:text-xl text-gray-400 mb-12 max-w-2xl mx-auto leading-relaxed">
          Own your files. Manage your library. Listen to everything — even video — as audio.
        </p>

        <!-- iPhone Mockup Placeholder -->
        <div class="mb-12">
          <div class="w-64 h-96 mx-auto bg-black rounded-3xl p-2 shadow-2xl">
            <div class="w-full h-full bg-gradient-to-b from-gray-900 to-gray-800 rounded-2xl flex items-center justify-center">
              <div class="text-center p-6">
                <div class="w-12 h-12 mx-auto mb-4 bg-blue-500 rounded-xl flex items-center justify-center">
                  <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
                <div class="text-white text-sm mb-2">Now Playing</div>
                <div class="text-gray-300 text-xs">Tam Listen Interface</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Download Button -->
        <div class="mb-8">
          <a 
            href="#" 
            class="inline-flex items-center px-8 py-4 bg-black text-white rounded-xl hover:bg-gray-800 transition-colors font-medium text-lg shadow-lg"
          >
            <svg class="w-8 h-8 mr-3" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            Download on the App Store
          </a>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold mb-6 text-white">Features</h2>
          <p class="text-xl text-gray-300 max-w-3xl mx-auto">
            Tam Listen is built for people who take listening seriously.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Your files, your way -->
          <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10">
            <div class="w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold mb-4 text-white">Your files, your way</h3>
            <p class="text-gray-300 leading-relaxed">
              Import from your device, Dropbox, or Google Drive. Once a file has presence in the app, you can offload it to free up space while keeping your progress and history. Bring it back when you're ready to continue. No subscriptions, no sync headaches, no algorithms deciding what's next.
            </p>
          </div>

          <!-- Video as audio -->
          <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10">
            <div class="w-12 h-12 bg-purple-500/20 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold mb-4 text-white">Video as audio</h3>
            <p class="text-gray-300 leading-relaxed">
              Lectures, talks, interviews — much of the best spoken content lives in video files. Tam Listen plays them as audio, so you can listen without the screen.
            </p>
          </div>

          <!-- CarPlay ready -->
          <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10">
            <div class="w-12 h-12 bg-green-500/20 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold mb-4 text-white">CarPlay ready</h3>
            <p class="text-gray-300 leading-relaxed mb-6">
              Full CarPlay support for long drives and daily commutes.
            </p>
            <!-- CarPlay Mockup -->
            <div class="w-full h-20 bg-black rounded-lg flex items-center justify-center">
              <div class="text-white text-sm">CarPlay Interface</div>
            </div>
          </div>

          <!-- Live Activities -->
          <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10">
            <div class="w-12 h-12 bg-orange-500/20 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold mb-4 text-white">Live Activities</h3>
            <p class="text-gray-300 leading-relaxed mb-6">
              Keep your current listen visible on your Lock Screen and Dynamic Island.
            </p>
            <!-- Live Activity Mockup -->
            <div class="w-full h-16 bg-black rounded-2xl flex items-center justify-between px-4">
              <div class="text-white text-xs">Now Playing</div>
              <div class="w-8 h-8 bg-blue-500 rounded-full"></div>
            </div>
          </div>

          <!-- Listening projects -->
          <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 md:col-span-2">
            <div class="w-12 h-12 bg-indigo-500/20 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold mb-4 text-white">Listening projects</h3>
            <p class="text-gray-300 leading-relaxed mb-6">
              Researching a subject? Bring together files and folders from across your library into a single project — lectures, interviews, audiobooks, whatever's relevant — and work through it over time.
            </p>
            <!-- Project View Mockup -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
              <div class="bg-gray-800 rounded-lg p-3 text-center">
                <div class="text-white text-xs">Lecture 1</div>
              </div>
              <div class="bg-gray-800 rounded-lg p-3 text-center">
                <div class="text-white text-xs">Interview</div>
              </div>
              <div class="bg-gray-800 rounded-lg p-3 text-center">
                <div class="text-white text-xs">Audiobook</div>
              </div>
              <div class="bg-gray-800 rounded-lg p-3 text-center">
                <div class="text-white text-xs">Podcast</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-bold mb-12 text-center text-white">About</h2>
        <div class="prose prose-lg prose-invert max-w-none">
          <p class="text-xl text-gray-300 leading-relaxed mb-8">
            Most apps that play files are designed for music or movies. You start a song or an album from the beginning. You watch a film right through. That's not how long-form spoken content works.
          </p>
          <p class="text-xl text-gray-300 leading-relaxed mb-8">
            With lectures, audiobooks, and interviews, you're working through material over days or weeks. You pick up where you left off. You miss a phrase and skip back a few seconds. You're not consuming — you're pursuing something.
          </p>
          <p class="text-xl text-gray-300 leading-relaxed">
            We built Tam Listen for that kind of listening.
          </p>
        </div>
      </div>
    </section>

    <!-- Support Section -->
    <section class="py-20 px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-white">Support</h2>
        <p class="text-lg text-gray-300 mb-8">
          Questions or issues? Reach us at 
          <a href="mailto:support@tambuzztam.com" class="text-blue-400 hover:text-blue-300 transition-colors">
            support@tambuzztam.com
          </a>
        </p>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 px-6 border-t border-white/10">
      <div class="max-w-4xl mx-auto text-center">
        <div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-8 text-gray-400">
          <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
          <span class="hidden sm:inline">·</span>
          <span>© tambuzztam LLC</span>
        </div>
      </div>
    </footer>
  </main>
</Layout>