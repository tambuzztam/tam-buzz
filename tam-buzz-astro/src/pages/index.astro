---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Tam - Philosophical Counseling">
  <!-- Hero Section -->
  <section
    class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 relative"
  >
    <div class="max-w-6xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold mb-6 leading-tight">
        Prize the problem
        <br class="hidden sm:block" />
        <span class="text-amber-400">Treasure the mind</span>
      </h1>
      <p
        class="text-xl sm:text-2xl lg:text-3xl text-gray-300 mb-12 max-w-4xl mx-auto"
      >
        Philosophical counseling for growing beings
      </p>
      <a
        href="https://calendly.com/tam-benp/philosophical-counseling"
        class="inline-block px-8 py-4 sm:px-12 sm:py-6 bg-blue-500 hover:bg-blue-600 text-white text-lg sm:text-xl font-semibold rounded-lg transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        Let's talk
      </a>

      <!-- Subtle navigation hint -->
      <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2">
        <a
          href="#problem"
          class="flex flex-col items-center text-gray-400 hover:text-white transition-colors group"
        >
          <span class="text-sm mb-2 opacity-75">Learn how it works</span>
          <svg
            class="w-6 h-6 animate-bounce"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section
    id="problem"
    class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 border-t border-gray-800 relative"
  >
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-center mb-16">
        What's important to you?
      </h2>
      <div
        class="prose prose-lg sm:prose-xl prose-invert max-w-4xl mx-auto text-center mb-12"
      >
        <p class="text-xl text-gray-300">
          We naturally respond to what's important by growing—with more of
          ourselves. When you discover what truly matters, growth happens
          naturally.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        <div class="space-y-6">
          <div class="border-l-4 border-blue-400 pl-6">
            <h3 class="text-xl font-semibold mb-3">
              What drives your choices?
            </h3>
            <p class="text-gray-300">
              When the values you thought you knew no longer seem to fit the
              person you're becoming
            </p>
          </div>
          <div class="border-l-4 border-amber-400 pl-6">
            <h3 class="text-xl font-semibold mb-3">
              What makes life meaningful?
            </h3>
            <p class="text-gray-300">
              When success feels empty and you find yourself asking deeper
              questions about purpose
            </p>
          </div>
        </div>
        <div class="space-y-6">
          <div class="border-l-4 border-emerald-400 pl-6">
            <h3 class="text-xl font-semibold mb-3">Who are you becoming?</h3>
            <p class="text-gray-300">
              When growth means letting go of old assumptions about yourself and
              embracing uncertainty
            </p>
          </div>
          <div class="border-l-4 border-purple-400 pl-6">
            <h3 class="text-xl font-semibold mb-3">How do you want to live?</h3>
            <p class="text-gray-300">
              When the tension between who you are and who you might become
              opens up new possibilities
            </p>
          </div>
        </div>
      </div>

      <!-- Let's talk CTA -->
      <div class="mt-12 text-center">
        <a
          href="https://calendly.com/tam-benp/philosophical-counseling"
          class="inline-block px-6 py-3 bg-blue-500/20 border border-blue-400/50 hover:bg-blue-500/30 hover:border-blue-400 text-blue-300 hover:text-blue-200 text-base font-medium rounded-lg transition-all"
          target="_blank"
          rel="noopener noreferrer"
        >
          Let's talk
        </a>
      </div>

      <!-- Subtle navigation hint -->
      <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2">
        <a
          href="#solution"
          class="flex flex-col items-center text-gray-400 hover:text-white transition-colors group"
        >
          <span class="text-sm mb-2 opacity-75">How philosophy helps</span>
          <svg
            class="w-6 h-6 animate-bounce"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Solution Section -->
  <section
    id="solution"
    class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 bg-gray-800/50 relative"
  >
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-center mb-16">
        Philosophic conversation
      </h2>
      <div class="prose prose-lg sm:prose-xl prose-invert max-w-none mb-16">
        <p class="text-xl text-center text-gray-300">
          Unlike therapy or coaching, our approach works with your natural
          response to importance. Through <em>philosophic</em> conversation, we help
          you hear what matters most—
          <br />and watch as you naturally grow with more of yourself.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div
            class="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center mx-auto mb-6"
          >
            <svg
              class="w-8 h-8 text-blue-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-4">Power listening</h3>
          <p class="text-gray-300">
            I come not with advice but with generative questions— helping you
            say something important about what's important
          </p>
        </div>
        <div class="text-center">
          <div
            class="w-16 h-16 bg-amber-500/20 rounded-full flex items-center justify-center mx-auto mb-6"
          >
            <svg
              class="w-8 h-8 text-amber-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-4">Natural growth</h3>
          <p class="text-gray-300">
            You respond to what's important by growing—it's your natural
            response. We help you hear what matters, and growth follows
          </p>
        </div>
        <div class="text-center">
          <div
            class="w-16 h-16 bg-emerald-500/20 rounded-full flex items-center justify-center mx-auto mb-6"
          >
            <svg
              class="w-8 h-8 text-emerald-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-4">Treasure the mind</h3>
          <p class="text-gray-300">
            Your thinking isn't broken—it's precious. We explore together what
            matters most
          </p>
        </div>
      </div>

      <!-- Let's talk CTA -->
      <div class="mt-8 text-center">
        <a
          href="https://calendly.com/tam-benp/philosophical-counseling"
          class="inline-block px-6 py-3 bg-blue-500/20 border border-blue-400/50 hover:bg-blue-500/30 hover:border-blue-400 text-blue-300 hover:text-blue-200 text-base font-medium rounded-lg transition-all"
          target="_blank"
          rel="noopener noreferrer"
        >
          Let's talk
        </a>
      </div>

      <!-- Subtle navigation hint -->
      <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2">
        <a
          href="#about"
          class="flex flex-col items-center text-gray-400 hover:text-white transition-colors group"
        >
          <span class="text-sm mb-2 opacity-75">About Tam</span>
          <svg
            class="w-6 h-6 animate-bounce"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section
    id="about"
    class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 relative"
  >
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-8">About Tam</h2>
      <div class="prose prose-lg sm:prose-xl prose-invert max-w-none mb-12">
        <p class="text-xl text-gray-300 mb-6">
          A special brand of philosophical counseling that honors you as a
          growing being. We work through <em>philosophic</em> conversations—not about
          philosophy itself, but about what's truly important to you.
        </p>
        <p class="text-lg text-gray-300 mb-6">
          I'm not here to give you wise advice or tell you what's important. I'm
          a power listener who helps you hear what already matters to you—
          because you naturally respond to importance by growing.
        </p>
        <p class="text-lg text-gray-400 mb-8">
          Certified by the <a
            href="https://appa.edu/about/"
            class="text-blue-400 hover:text-blue-300 underline">APPA</a
          > (American Philosophical Practitioners Association).
        </p>
        <blockquote class="text-2xl font-medium italic border-none">
          "The counselor comes not with advice but with generative questions,<br
          />
          a fortifying curiosity"
        </blockquote>
      </div>

      <!-- Let's talk CTA -->
      <div class="mt-8 text-center">
        <a
          href="https://calendly.com/tam-benp/philosophical-counseling"
          class="inline-block px-6 py-3 bg-blue-500/20 border border-blue-400/50 hover:bg-blue-500/30 hover:border-blue-400 text-blue-300 hover:text-blue-200 text-base font-medium rounded-lg transition-all"
          target="_blank"
          rel="noopener noreferrer"
        >
          Let's talk
        </a>
      </div>

      <!-- Subtle navigation hint -->
      <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2">
        <a
          href="#process"
          class="flex flex-col items-center text-gray-400 hover:text-white transition-colors group"
        >
          <span class="text-sm mb-2 opacity-75">What to expect</span>
          <svg
            class="w-6 h-6 animate-bounce"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section
    id="process"
    class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 bg-gray-800/50 relative"
  >
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-16">
        What to expect
      </h2>
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="space-y-6 text-left">
          <div class="flex items-start space-x-4">
            <div
              class="flex-shrink-0 w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center mt-1"
            >
              <span class="text-sm font-bold">1</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">
                Philosophic conversation
              </h3>
              <p class="text-gray-300">
                50 minutes focused on what's truly important to you— not
                philosophy, but your philosophy of living
              </p>
            </div>
          </div>
          <div class="flex items-start space-x-4">
            <div
              class="flex-shrink-0 w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center mt-1"
            >
              <span class="text-sm font-bold">2</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">You do the talking</h3>
              <p class="text-gray-300">
                I listen for what's already growing in you—helping you hear
                what's important so you can respond with more of yourself
              </p>
            </div>
          </div>
          <div class="flex items-start space-x-4">
            <div
              class="flex-shrink-0 w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center mt-1"
            >
              <span class="text-sm font-bold">3</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">Growth, not healing</h3>
              <p class="text-gray-300">
                You're not broken—you're growing. We honor that becoming
              </p>
            </div>
          </div>
        </div>
        <div class="bg-gray-900 rounded-lg p-8">
          <h3 class="text-2xl font-semibold mb-4">The Experience</h3>
          <p class="text-gray-300 mb-6">
            Meet via Zoom or in-person. No homework, no diagnosis, no fixing.
            Just treasuring your mind through deep conversation.
          </p>
          <p class="text-gray-400">
            When you hear what's truly important, you naturally respond by
            growing. The conversation creates space for this natural response to
            unfold.
          </p>
        </div>
      </div>

      <!-- Let's talk CTA -->
      <div class="mt-8 text-center">
        <a
          href="https://calendly.com/tam-benp/philosophical-counseling"
          class="inline-block px-6 py-3 bg-blue-500/20 border border-blue-400/50 hover:bg-blue-500/30 hover:border-blue-400 text-blue-300 hover:text-blue-200 text-base font-medium rounded-lg transition-all"
          target="_blank"
          rel="noopener noreferrer"
        >
          Let's talk
        </a>
      </div>

      <!-- Subtle navigation hint -->
      <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2">
        <a
          href="#cta"
          class="flex flex-col items-center text-gray-400 hover:text-white transition-colors group"
        >
          <span class="text-sm mb-2 opacity-75">Ready to start?</span>
          <svg
            class="w-6 h-6 animate-bounce"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section
    id="cta"
    class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 relative"
  >
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-8">
        Ready to explore your questions?
      </h2>
      <p class="text-xl text-gray-300 mb-12">
        Schedule your philosophical counseling session
      </p>
      <a
        href="https://calendly.com/tam-benp/philosophical-counseling"
        class="inline-block px-12 py-6 bg-blue-500 hover:bg-blue-600 text-white text-xl font-semibold rounded-lg transition-colors mb-8"
        target="_blank"
        rel="noopener noreferrer"
      >
        Schedule Your Session
      </a>
      <p class="text-gray-400">
        Questions? Email <a
          href="mailto:info@tam.buzz"
          class="text-blue-400 hover:text-blue-300">info@tam.buzz</a
        >
      </p>
    </div>
  </section>

  <!-- Progressive Disclosure to Heights/Depths -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 border-t border-gray-800">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-8">
        Ready to explore deeper?
      </h2>
      <p class="text-xl text-gray-300 mb-16">
        Every meaningful question invites both elevation and excavation
      </p>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <a href="/heights" class="group block">
          <div
            class="border border-blue-400 rounded-lg p-8 hover:bg-blue-400/10 transition-colors"
          >
            <div
              class="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform"
            >
              <svg
                class="w-8 h-8 text-blue-400 group-hover:-translate-y-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold mb-4">The Heights</h3>
            <p class="text-gray-300 mb-6">
              Gain perspective on your life's direction
            </p>
            <p class="text-sm text-gray-400">
              Vision, meaning, and frameworks for living
            </p>
          </div>
        </a>

        <a href="/depths" class="group block">
          <div
            class="border border-amber-400 rounded-lg p-8 hover:bg-amber-400/10 transition-colors"
          >
            <div
              class="w-16 h-16 bg-amber-500/20 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform"
            >
              <svg
                class="w-8 h-8 text-amber-400 group-hover:translate-y-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold mb-4">The Depths</h3>
            <p class="text-gray-300 mb-6">
              Examine the foundations of your assumptions
            </p>
            <p class="text-sm text-gray-400">
              Core beliefs, hidden assumptions, and root causes
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>
