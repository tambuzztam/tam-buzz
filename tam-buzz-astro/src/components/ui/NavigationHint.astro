---
export interface Props {
  href: string;
  text: string;
}

const { href, text } = Astro.props;
---

<!-- Subtle navigation hint -->
<div class="w-full flex justify-center pb-8 pt-4">
  <a
    href={href}
    class="nav-hint flex flex-col items-center text-gray-400 hover:text-white transition-colors group"
  >
    <span class="text-sm mb-2 opacity-75">{text}</span>
    <svg
      class="w-6 h-6 animate-bounce"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </a>
</div>

<script>
  // Shared state so rapid clicks don't leave snap permanently disabled
  let _snapTimer = null;
  let _scrollEndHandler = null;

  function scrollWithoutSnap(target) {
    const html = document.documentElement;

    clearTimeout(_snapTimer);
    if (_scrollEndHandler) {
      window.removeEventListener("scrollend", _scrollEndHandler);
      _scrollEndHandler = null;
    }

    html.style.scrollSnapType = "none";
    target.scrollIntoView({ behavior: "smooth", block: "start" });

    function restore() {
      html.style.scrollSnapType = "";
      _snapTimer = null;
      _scrollEndHandler = null;
    }

    if ("onscrollend" in window) {
      _scrollEndHandler = () => {
        clearTimeout(_snapTimer);
        restore();
      };
      window.addEventListener("scrollend", _scrollEndHandler, { once: true });
      _snapTimer = setTimeout(() => {
        if (_scrollEndHandler) {
          window.removeEventListener("scrollend", _scrollEndHandler);
        }
        restore();
      }, 1500);
    } else {
      _snapTimer = setTimeout(restore, 1500);
    }
  }

  document.querySelectorAll(".nav-hint").forEach((link) => {
    link.addEventListener("click", (e) => {
      const href = link.getAttribute("href");
      if (!href?.startsWith("#")) return;

      const target = document.querySelector(href);
      if (!target) return;

      e.preventDefault();
      scrollWithoutSnap(target);
    });
  });
</script>
