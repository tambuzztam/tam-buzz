---
export interface Props {
  variant?: "primary" | "secondary" | "large";
  text?: string;
  href?: string;
}

const {
  variant = "primary",
  text = "Let's talk",
  href = "https://calendly.com/tam-benp/philosophical-counseling",
} = Astro.props;

const getButtonClasses = (variant: string) => {
  switch (variant) {
    case "large":
      return "inline-block px-8 py-4 sm:px-12 sm:py-6 bg-blue-500 hover:bg-blue-600 text-white text-lg sm:text-xl font-semibold rounded-lg transition-colors";
    case "secondary":
      return "inline-block px-6 py-3 bg-blue-500/20 border border-blue-400/50 hover:bg-blue-500/30 hover:border-blue-400 text-blue-300 hover:text-blue-200 text-base font-medium rounded-lg transition-all";
    default:
      return "inline-block px-12 py-6 bg-blue-500 hover:bg-blue-600 text-white text-xl font-semibold rounded-lg transition-colors";
  }
};
---

<a
  href={href}
  class={getButtonClasses(variant)}
  target="_blank"
  rel="noopener noreferrer"
>
  {text}
</a>
