<script>
  // Keyboard navigation for arrow keys
  document.addEventListener("DOMContentLoaded", () => {
    const sections = Array.from(document.querySelectorAll("section[id]"));

    const heroSection = document.querySelector("section");
    if (heroSection && !heroSection.id) {
      sections.unshift(heroSection);
    }

    let currentSectionIndex = 0;

    function getCurrentSection() {
      const scrollPosition = window.scrollY + window.innerHeight / 2;

      for (let i = 0; i < sections.length; i++) {
        const section = sections[i];
        const rect = section.getBoundingClientRect();
        const sectionTop = window.scrollY + rect.top;
        const sectionBottom = sectionTop + rect.height;

        if (scrollPosition >= sectionTop && scrollPosition <= sectionBottom) {
          return i;
        }
      }
      return 0;
    }

    // Temporarily disable scroll-snap during programmatic scrolling.
    // Uses the scrollend event (with a timeout fallback) so snap isn't
    // re-enabled before the scroll finishes — which previously caused
    // proximity snap to yank the viewport back to the wrong section.
    let _snapTimer = null;
    let _scrollEndHandler = null;

    function scrollWithoutSnap(el) {
      const html = document.documentElement;

      // Cancel any pending restore from a previous call
      clearTimeout(_snapTimer);
      if (_scrollEndHandler) {
        window.removeEventListener("scrollend", _scrollEndHandler);
        _scrollEndHandler = null;
      }

      html.style.scrollSnapType = "none";
      el.scrollIntoView({ behavior: "smooth", block: "start" });

      // Always restore to "" so the CSS rule takes effect again —
      // avoids the race where a second call captures "none" as the
      // "original" value and permanently disables snap.
      function restore() {
        html.style.scrollSnapType = "";
        _snapTimer = null;
        _scrollEndHandler = null;
      }

      if ("onscrollend" in window) {
        _scrollEndHandler = () => {
          clearTimeout(_snapTimer);
          restore();
        };
        window.addEventListener("scrollend", _scrollEndHandler, { once: true });
        _snapTimer = setTimeout(() => {
          if (_scrollEndHandler) {
            window.removeEventListener("scrollend", _scrollEndHandler);
          }
          restore();
        }, 1500);
      } else {
        _snapTimer = setTimeout(restore, 1500);
      }
    }

    function scrollToNextSection() {
      currentSectionIndex = getCurrentSection();
      const nextIndex = Math.min(currentSectionIndex + 1, sections.length - 1);

      if (nextIndex > currentSectionIndex) {
        scrollWithoutSnap(sections[nextIndex]);
      }
    }

    function scrollToPreviousSection() {
      currentSectionIndex = getCurrentSection();
      const prevIndex = Math.max(currentSectionIndex - 1, 0);

      if (prevIndex < currentSectionIndex) {
        scrollWithoutSnap(sections[prevIndex]);
      }
    }

    document.addEventListener("keydown", (event) => {
      const tag = document.activeElement?.tagName?.toLowerCase();
      if (
        tag === "input" ||
        tag === "textarea" ||
        tag === "select" ||
        document.activeElement?.isContentEditable
      ) {
        return;
      }

      if (event.key === "ArrowDown" || event.keyCode === 40) {
        event.preventDefault();
        scrollToNextSection();
      } else if (event.key === "ArrowUp" || event.keyCode === 38) {
        event.preventDefault();
        scrollToPreviousSection();
      }
    });

    let scrollTimeout;
    window.addEventListener("scroll", () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        currentSectionIndex = getCurrentSection();
      }, 100);
    });
  });
</script>
