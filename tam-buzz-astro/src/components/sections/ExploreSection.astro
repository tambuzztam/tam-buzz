---

---

<!-- Progressive Disclosure to Heights/Depths -->
<section class="py-20 px-4 sm:px-6 lg:px-8 border-t border-gray-800">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="text-3xl sm:text-4xl font-bold mb-8">
      Ready to explore deeper?
    </h2>
    <p class="text-xl text-gray-300 mb-16">
      Every meaningful question invites both elevation and excavation
    </p>

    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <a href="/heights" class="group block">
        <div
          class="border border-blue-400 rounded-lg p-8 hover:bg-blue-400/10 transition-colors"
        >
          <div
            class="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform"
          >
            <svg
              class="w-8 h-8 text-blue-400 group-hover:-translate-y-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold mb-4">The Heights</h3>
          <p class="text-gray-300 mb-6">
            Gain perspective on your life's direction
          </p>
          <p class="text-sm text-gray-400">
            Vision, meaning, and frameworks for living
          </p>
        </div>
      </a>

      <a href="/depths" class="group block">
        <div
          class="border border-amber-400 rounded-lg p-8 hover:bg-amber-400/10 transition-colors"
        >
          <div
            class="w-16 h-16 bg-amber-500/20 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform"
          >
            <svg
              class="w-8 h-8 text-amber-400 group-hover:translate-y-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold mb-4">The Depths</h3>
          <p class="text-gray-300 mb-6">
            Examine the foundations of your assumptions
          </p>
          <p class="text-sm text-gray-400">
            Core beliefs, hidden assumptions, and root causes
          </p>
        </div>
      </a>
    </div>
  </div>
</section>
