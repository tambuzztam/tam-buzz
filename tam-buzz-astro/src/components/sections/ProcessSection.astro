---
import CTAButton from "../ui/CTAButton.astro";
import NavigationHint from "../ui/NavigationHint.astro";
---

<!-- Process Section -->
<section
  id="process"
  class="snap-none-mobile pt-24 pb-20 md:py-20 md:min-h-[100dvh] flex flex-col px-4 sm:px-6 lg:px-8"
>
  <div
    class="max-w-4xl mx-auto text-center flex-1 flex flex-col justify-center"
  >
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-16">
      What to expect
    </h2>
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-6 text-left">
        <div class="flex items-start space-x-4">
          <div
            class="flex-shrink-0 w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center mt-1"
          >
            <span class="text-sm font-bold">1</span>
          </div>
          <div>
            <h3 class="text-xl font-semibold mb-2">
              Free introductory session
            </h3>
            <p class="text-gray-300">
              60 minutes for us to meet and ensure we're right for each other—a
              mutual audition where we explore what's important to you
            </p>
          </div>
        </div>
        <div class="flex items-start space-x-4">
          <div
            class="flex-shrink-0 w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center mt-1"
          >
            <span class="text-sm font-bold">2</span>
          </div>
          <div>
            <h3 class="text-xl font-semibold mb-2">Eight-session series</h3>
            <p class="text-gray-300">
              If we're a good fit, we begin with eight sessions that form a
              coherent whole—your philosophical counselor as ongoing companion
              in growth
            </p>
          </div>
        </div>
        <div class="flex items-start space-x-4">
          <div
            class="flex-shrink-0 w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center mt-1"
          >
            <span class="text-sm font-bold">3</span>
          </div>
          <div>
            <h3 class="text-xl font-semibold mb-2">Beautiful frequency</h3>
            <p class="text-gray-300">
              This is dwelling on what's important, not treatment — so we meet
              when it's right, often every other week, in a rhythm shaped by
              your life rather than some clinical schedule
            </p>
          </div>
        </div>
        <div class="flex items-start space-x-4">
          <div
            class="flex-shrink-0 w-8 h-8 bg-amber-500 rounded-full flex items-center justify-center mt-1"
          >
            <span class="text-lg font-bold">✦</span>
          </div>
          <div>
            <h3 class="text-xl font-semibold mb-2">Artifacts you keep</h3>
            <p class="text-gray-300">
              Unlike therapy where much is better forgotten, our conversations
              generate artifacts — audio files and clean transcripts that are
              yours to keep, if you're interested. The audio can join your
              library; the transcripts are yours for ongoing exploration
            </p>
          </div>
        </div>
      </div>
      <div class="bg-gray-900 rounded-lg p-8">
        <h3 class="text-2xl font-semibold mb-4">The Experience</h3>
        <p class="text-gray-300 mb-6">
          Meet via Zoom or in-person. No homework, no diagnosis, no fixing. Come
          with what's on your mind, what's happening, what you're learning, or
          come ready to discover what is — drawing out your hidden reserves is
          part of this practice.
        </p>
        <p class="text-gray-300 mb-4">
          Through philosophic conversation, we work by listening rather than by
          observation and measurement. You cannot detect growth with the naked
          eye, but you can hear it. The ongoing engagement with what you know is
          what makes you more than what you were.
        </p>
        <p class="text-gray-400 text-sm">
          Optional: each session produces audio files and crafted transcripts —
          artifacts that become part of your library, available for return and
          further inquiry.
        </p>
      </div>
    </div>

    <!-- Let's talk CTA -->
    <div class="mt-8 text-center">
      <CTAButton variant="secondary" />
    </div>

    <NavigationHint href="#legacy" text="What you leave behind" />
  </div>
</section>
