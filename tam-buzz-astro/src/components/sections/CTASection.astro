---
import CTAButton from "../ui/CTAButton.astro";
const year = new Date().getFullYear();
---

<!-- CTA Section -->
<section
  id="cta"
  class="min-h-[100dvh] flex flex-col px-4 sm:px-6 lg:px-8 relative"
>
  <div class="flex-1 flex items-center justify-center">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">Ready? Let's begin!</h2>
      <p
        class="text-lg sm:text-xl uppercase tracking-widest text-amber-400/80 mb-8"
      >
        The first conversation is on us
      </p>
      <p class="text-xl text-gray-300 mb-12">
        Begin with a conversation about what's important to you. We start with a
        complimentary introductory session—a chance for us to meet and ensure
        we're right for each other.
      </p>
      <CTAButton variant="primary" text="Schedule Your Free Session" />
      <p class="text-gray-400 mt-8">
        Questions? Email <a
          href="mailto:info@tam.buzz"
          class="text-amber-400 hover:text-amber-300">info@tam.buzz</a
        >
      </p>
    </div>
  </div>

  <footer class="py-8 border-t border-white/10">
    <div
      class="flex flex-col sm:flex-row items-center justify-center space-y-3 sm:space-y-0 sm:space-x-8 text-sm text-gray-500"
    >
      <a href="/privacy/" class="footer-link">Privacy Policy</a>
      <span class="hidden sm:inline">·</span>
      <a href="/terms/" class="footer-link">Terms of Service</a>
      <span class="hidden sm:inline">·</span>
      <span>© {year} tambuzztam LLC</span>
    </div>
  </footer>
</section>

<style>
  .footer-link {
    color: #9ca3af;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: #fbbf24;
  }
</style>
