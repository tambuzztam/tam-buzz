---
import CTAButton from "../ui/CTAButton.astro";
---

<!-- CTA Section -->
<section
  id="cta"
  class="min-h-[100dvh] flex items-center justify-center px-4 sm:px-6 lg:px-8 relative"
>
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl sm:text-4xl font-bold mb-4">Ready? Let's begin!</h2>
    <p
      class="text-lg sm:text-xl uppercase tracking-widest text-amber-400/80 mb-8"
    >
      The first conversation on us
    </p>
    <p class="text-xl text-gray-300 mb-12">
      Begin with a conversation about what's important to you. We start with a
      complimentary introductory session—a chance for us to meet and ensure
      we're right for each other.
    </p>
    <CTAButton variant="primary" text="Schedule Your Free Session" />
    <p class="text-gray-400 mt-8">
      Questions? Email <a
        href="mailto:info@tam.buzz"
        class="text-blue-400 hover:text-blue-300">info@tam.buzz</a
      >
    </p>
  </div>
</section>
