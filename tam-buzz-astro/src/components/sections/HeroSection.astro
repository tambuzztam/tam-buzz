---
import CTAButton from "../ui/CTAButton.astro";
import NavigationHint from "../ui/NavigationHint.astro";
---

<!-- Hero Section -->
<section
  class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 relative"
>
  <div class="max-w-6xl mx-auto text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold mb-6 leading-tight">
      Prize the problems
      <br class="hidden sm:block" />
      <span class="text-amber-400">Treasure the mind</span>
    </h1>
    <p
      class="text-xl sm:text-2xl lg:text-3xl text-gray-300 mb-12 max-w-4xl mx-auto"
    >
      Tam - Philosophical Counseling
    </p>
    <CTAButton variant="large" />

    <NavigationHint href="#problem" text="Learn how it works" />
  </div>
</section>
