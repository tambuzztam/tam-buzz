---
import CTAButton from "../ui/CTAButton.astro";
import NavigationHint from "../ui/NavigationHint.astro";
---

<!-- Hero Section -->
<section
  class="min-h-screen flex flex-col px-4 sm:px-6 lg:px-8"
>
  <div class="max-w-6xl mx-auto text-center flex-1 flex flex-col items-center justify-center">
    <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold mb-6 leading-tight">
      Prize the problems
      <br class="hidden sm:block" />
      <span class="text-amber-400">Treasure the mind</span>
    </h1>
    <p class="text-xl sm:text-2xl lg:text-3xl text-gray-300 mb-2 max-w-4xl mx-auto">
      Active enjoyment of what you know deep down
    </p>
    <p class="text-base sm:text-lg text-gray-400 mb-12">
      Tam Philosophical Counseling
    </p>
    <CTAButton variant="large" />

    <NavigationHint href="#reserves" text="Learn how it works" />
  </div>
</section>
