---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Prize the problems, treasure the mind. Philosophic conversation that draws out your reserves of knowledge deep down — not therapy, not coaching, but an enjoyment layer for what you already know.",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="theme-color" content="#111827" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Tam Philosophical Counseling" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title}</title>
    <slot name="head" />

    <!-- Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        name: "Tam Philosophical Counseling",
        url: "https://tam.buzz",
        description: description,
        serviceType: "Philosophical Counseling",
        areaServed: "Worldwide",
        availableChannel: {
          "@type": "ServiceChannel",
          serviceUrl: "https://tam.buzz",
          availableLanguage: "English",
        },
      })}
    />
  </head>
  <body class="bg-gray-900 text-gray-100 antialiased relative">
    <!-- Background Image -->
    <div
      class="bg-backdrop -z-10 opacity-50"
      style="background-image: url('/inverse_coldmountain.jpg'); background-size: cover; background-repeat: no-repeat; background-position: center;"
    >
    </div>
    <div
      class="bg-backdrop -z-10 bg-gradient-to-b from-gray-900/40 via-gray-900/60 to-gray-900/70"
    >
    </div>
    <slot />
  </body>
</html>

<style is:global>
  html {
    font-family: system-ui, sans-serif;
    scroll-snap-type: y proximity;
    scroll-behavior: auto;
    -webkit-overflow-scrolling: touch;
  }

  /* Mobile: disable snap (avoids jumpy proximity behaviour) */
  @media (max-width: 767px) {
    html {
      scroll-snap-type: none;
    }
  }

  /* Enable smooth scrolling only when the user has no motion preference */
  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }

  /* Use mandatory snap only on larger screens where sections fit the viewport */
  @media (min-width: 768px) {
    html {
      scroll-snap-type: y mandatory;
    }
  }

  section {
    scroll-snap-align: start;
  }

  /* Content-heavy sections opt out of snap on mobile */
  @media (max-width: 767px) {
    section.snap-none-mobile {
      scroll-snap-align: none;
    }
  }

  /* Shared fixed backdrop layer — uses 100vh as fallback, 100lvh where supported */
  .bg-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 100vh;
    height: 100lvh;
  }
</style>
