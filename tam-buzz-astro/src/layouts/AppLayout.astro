---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "An audio player for power listeners. Own your files. Manage your library. Listen to everything — even video — as audio.",
  ogImage = "/og-image-listen.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="theme-color" content="#000000" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Tam Listen" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/listen.webmanifest" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title}</title>

    <!-- Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "Tam Listen",
        url: "https://tam.buzz/listen",
        applicationCategory: "MultimediaApplication",
        operatingSystem: "iOS",
        description: description,
        offers: {
          "@type": "Offer",
          availability: "https://schema.org/InStock",
          price: "0",
          priceCurrency: "USD",
        },
      })}
    />
  </head>
  <body class="bg-black text-gray-100 antialiased relative">
    <!-- App-specific gradient background -->
    <div
      class="fixed inset-0 -z-10"
      style="background: linear-gradient(135deg, #000000 0%, #0f0f0f 40%, #1a1a1a 70%, #1a1f1a 100%);"
    >
    </div>
    <!-- Mountain background overlay at low opacity -->
    <div
      class="fixed inset-0 -z-10"
      style="
        background-image: url('/inverse_coldmountain.jpg'); 
        background-size: cover; 
        background-repeat: no-repeat; 
        background-position: center;
        opacity: 0.03;
      "
    >
    </div>
    <slot />
  </body>
</html>

<style is:global>
  html {
    font-family: system-ui, sans-serif;
    scroll-snap-type: y proximity;
    scroll-behavior: smooth;
    background-color: #000000;
  }

  section {
    scroll-snap-align: start;
  }

  /* Ensure smooth scrolling works across browsers */
  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }
</style>
