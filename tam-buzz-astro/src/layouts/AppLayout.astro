---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "A file-first listening app for people with real media libraries. Play audio and video container files, organize with projects, and listen to everything.",
  ogImage = "/og-image-listen.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="theme-color" content="#000000" />
    <meta name="apple-itunes-app" content="app-id=6760617958" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Tam Listen" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/listen.webmanifest" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title}</title>

    <!-- Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "Tam Listen",
        url: "https://tam.buzz/listen/",
        applicationCategory: "MultimediaApplication",
        operatingSystem: "iOS",
        description: description,
        offers: {
          "@type": "Offer",
          availability: "https://schema.org/InStock",
          price: "0",
          priceCurrency: "USD",
        },
      })}
    />
  </head>
  <body class="text-gray-100 antialiased relative bg-black">
    <div class="bg-backdrop-stack z-0 pointer-events-none">
      <div
        class="bg-backdrop opacity-50"
        style="background-image: url('/inverse_coldmountain.jpg'); background-size: cover; background-repeat: no-repeat; background-position: center;"
      >
      </div>
      <div
        class="bg-backdrop"
        style="background: linear-gradient(135deg, rgba(0,0,0,0.94) 0%, rgba(15,15,15,0.95) 40%, rgba(26,26,26,0.96) 70%, rgba(26,31,26,0.97) 100%);"
      >
      </div>
    </div>
    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  html {
    font-family: system-ui, sans-serif;
    scroll-snap-type: y proximity;
    scroll-behavior: smooth;
    background-color: #000000;
  }

  section {
    scroll-snap-align: start;
  }

  /* Ensure smooth scrolling works across browsers */
  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }
  .bg-backdrop-stack {
    position: fixed;
    inset: 0;
  }

  .bg-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    height: 100vh;
    height: 100lvh;
  }
</style>
